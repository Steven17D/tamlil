# Pre-push gate: ruff + pytest always; the Swift self-check only when the
# pushed commits touch Tamlil/ (it costs a swift build). Install once with
# `make hooks`.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

uv run ruff check .
uv run pytest -q

zero=0000000000000000000000000000000000000000
need_swift=0
while read -r _ local_sha _ remote_sha; do
  [ "$local_sha" = "$zero" ] && continue   # deleting a remote branch
  if [ "$remote_sha" = "$zero" ]; then
    # New remote branch: no base to diff against, so be safe and check.
    need_swift=1
  elif git diff --name-only "$remote_sha..$local_sha" -- Tamlil/ | grep -q .; then
    need_swift=1
  fi
done

if [ "$need_swift" = 1 ]; then
  (cd Tamlil && swift run Tamlil --self-check)
fi
